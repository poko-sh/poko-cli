{
  "name": "@poko.sh/cli",
  "version": "0.1.0",
  "description": "Your pocket context buddy for AI coding agents.",
  "type": "module",
  "bin": {
    "poko": "dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "docs",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "bun src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "format": "biome format --write .",
    "build": "bun build ./src/cli.ts --outdir ./dist --target bun",
    "compile": "bun build ./src/cli.ts --compile --outfile ./bin/poko",
    "compile:darwin-arm64": "bun build ./src/cli.ts --compile --target=bun-darwin-arm64 --outfile ./dist/sidecars/poko-aarch64-apple-darwin",
    "compile:darwin-x64": "bun build ./src/cli.ts --compile --target=bun-darwin-x64 --outfile ./dist/sidecars/poko-x86_64-apple-darwin",
    "compile:linux-x64": "bun build ./src/cli.ts --compile --target=bun-linux-x64 --outfile ./dist/sidecars/poko-x86_64-unknown-linux-gnu",
    "compile:windows-x64": "bun build ./src/cli.ts --compile --target=bun-windows-x64 --outfile ./dist/sidecars/poko-x86_64-pc-windows-msvc.exe",
    "lab": "bun lab/poko-lab.ts",
    "lab:reset": "bun lab/poko-lab.ts reset",
    "lab:smoke": "bun lab/poko-lab.ts smoke",
    "lab:gate": "bun lab/poko-lab.ts gate",
    "lab:scenario": "bun lab/poko-lab.ts scenario",
    "lab:report": "bun lab/poko-lab.ts report",
    "lab:docker": "docker compose -f lab/docker-compose.yml run --rm poko-lab"
  },
  "keywords": [
    "ai",
    "cli",
    "context",
    "claude",
    "cursor",
    "pi",
    "opencode",
    "hermes",
    "openclaw",
    "codex"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/poko-sh/poko-cli.git"
  },
  "homepage": "https://github.com/poko-sh/poko-cli#readme",
  "bugs": {
    "url": "https://github.com/poko-sh/poko-cli/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "picocolors": "^1.1.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/bun": "^1.2.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
